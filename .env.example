# Секретный ключ для JWT токенов (минимум 32 случайных символа)
# Сгенерировать можно командой: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Настройки базы данных
DB_HOST=localhost
DB_PORT=5432
DB_NAME=paint_online
DB_USER=postgres
DB_PASSWORD=your_password

# Настройки Redis
REDIS_URL=redis://localhost:6379

# Порт сервера
PORT=5000

# Режим работы (development/production)
NODE_ENV=development

# Пароль администратора по умолчанию (обязательно измените в production!)
ADMIN_DEFAULT_PASSWORD=

# Email поддержки
SUPPORT_EMAIL=support@paint-online.ru

# URL фронтенда
FRONTEND_URL=http://localhost:3000
